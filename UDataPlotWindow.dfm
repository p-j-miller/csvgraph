    object FilterType: TListBox
      Left = 0
      Top = 829
      Width = 167
      Height = 93
      Hint = 
        'Select filtering required - you may also need to set the filter ' +
        'time constant or polynomial order'
      Anchors = [akTop, akRight]
      Font.Charset = DEFAULT_CHARSET
      Font.Color = clWindowText
      Font.Height = -12
      Font.Name = 'Segoe UI'
      Font.Style = []
      ItemHeight = 15
      Items.Strings = (
        'None'
        'Recursive Median Filter'
        'Standard Median Filter'
        'Savitzky Golay smoothing'
        'Smoothing spline Filter'
        'Linear Filter order:'
        'Central moving average Filter'
        'Kalman Filter'
        'Lin.regression: y=mx'
        'Lin. regression: y=mx+c'
        'GMR regression: y=mx+c'
        'min abs err: y=mx+c'
        'min rel err: y=mx+c'
        'Log: y=m*log(x)+c'
        'Exponential: y=c*exp(mx)'
        'Power: y=c*x^m'
        'Recip: y=m/x+c'
        'y=1/(mx+c)'
        'Hyperbolic: y=x/(m+c*x)'
        'sqrt: y=m*sqrt(x)+c'
        'y=m*x*log2(x)+c'
        'y=a*x+b*sqrt(x)+c'
        'y=a+bx^0.5+cx+dx^1.5'
        'y=(a+bx)/(1+cx)'
        'y=(a+bx+cx2)/(1+dx+ex2)'
        'Polynomial fit order:'
        'Poly in sqrt(x) order:'
        'rational (poly/poly) order:'
        'Derivative (dy/dx)'
        '2nd derivative (d2y/d2x)'
        'Integral (y dx)'
        'FFT returns |magnitude|'
        'FFT returns dBV'
        'FFT windowed |mag|'
        'FFT  windowed dBV'
        'Real Cepstrum')
      ParentFont = False
      ParentShowHint = False
      ShowHint = True
      TabOrder = 3
    end
